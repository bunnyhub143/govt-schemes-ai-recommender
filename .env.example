# Copy to .env and fill in. Do not commit .env.

# Required for secure sessions (change in production)
SECRET_KEY=your-secret-key-here

# PostgreSQL database (required)
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/schemes_db

# Required for sending OTP emails (e.g. Gmail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
